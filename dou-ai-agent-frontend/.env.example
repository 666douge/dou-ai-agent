# .env.example — 复制此文件并改名后使用
# 开发环境: cp .env.example .env.local  (npm run dev 优先读取 .env.local)
# 生产构建: cp .env.example .env.production  (npm run build 读取 .env.production)

# ══════════════════════════════════════════════════
# 后端 API 地址
# ══════════════════════════════════════════════════
# 相对路径：开发模式走 Vite proxy（localhost:3000 → 后端 proxy），无需 CORS 配置
VITE_API_BASE_URL=/api

# 绝对 URL：部署到生产环境时取消注释，填入实际后端域名
# VITE_API_BASE_URL=https://your-backend-domain.com

# ══════════════════════════════════════════════════
# 站点 SEO / 品牌
# ══════════════════════════════════════════════════
VITE_SITE_URL=https://your-domain.com
VITE_OG_IMAGE=/og-default.png
VITE_SITE_NAME=Dou AI Agent
