# .env — 开发/生产环境配置
# 开发环境：复制此文件为 .env.dev（npm run dev 使用 .env.dev）
# 生产环境：复制为 .env.production（npm run build 使用 .env.production）

# ══════════════════════════════════════════════════
# 后端 API 地址
# ══════════════════════════════════════════════════
# 相对路径（开发模式走 Vite proxy，避免 CORS）
VITE_API_BASE_URL=/api
# 绝对 URL（生产环境，填入实际后端域名）
# VITE_API_BASE_URL=https://dou-ai-agent-backend-243555-6-1420044929.sh.run.tcloudbase.com

# ══════════════════════════════════════════════════
# 站点 SEO
# ══════════════════════════════════════════════════
VITE_SITE_URL=https://douaiagent.com
VITE_OG_IMAGE=/og-default.png
VITE_SITE_NAME=Dou AI Agent
